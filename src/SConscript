# Build: Compiler libraries + brick CLI
Import('env', 'platform_libs', 'has_visualizer', 'target', 'has_x11')

import sys, os

# ─── Generate embedded runtime ──────────────────────────────
out_dir = Dir('#src').abspath
gen_h   = os.path.join(out_dir, 'embedded_runtime.h')
gen_cpp = os.path.join(out_dir, 'embedded_runtime.cpp')

embed_cmd = (
    f'{sys.executable} {File("#scripts/embed_runtime.py").abspath}'
    f' --target {target}'
    f' --runtime-dir {Dir("#runtime").abspath}'
    f' --out-h {gen_h}'
    f' --out-cpp {gen_cpp}'
)
if target == 'linux' and has_x11:
    embed_cmd += ' --has-x11'

# All runtime source files trigger regeneration
# Todos os arquivos fonte de runtime disparam regeneracao
runtime_deps = Glob('#runtime/*.h') + Glob('#runtime/*.c')
if target == 'linux':
    runtime_deps += Glob('#runtime/hot_reload*')
    runtime_deps += Glob('#runtime/libs/window/*')
if has_x11:
    runtime_deps += Glob('#runtime/libs/window/*.c')
    runtime_deps += Glob('#runtime/libs/window/*.h')
env.Command([gen_h, gen_cpp], ['#scripts/embed_runtime.py'] + runtime_deps, embed_cmd)

# ─── Libraries ──────────────────────────────────────────────
lib_lexer   = env.Library('#build/brick_lexer',   ['lexer/lexer.cpp'])
lib_parser  = env.Library('#build/brick_parser',  ['parser/parser.cpp',
                                                   'parser/package.cpp'])
lib_codegen = env.Library('#build/brick_codegen', ['codegen/codegen.cpp',
                                                   'codegen/type_checker.cpp'])
lib_shared  = env.Library('#build/brick_shared',  ['shared/lsp.cpp',
                                                   gen_cpp])

# ─── CLI Program ────────────────────────────────────────────
brick_libs = [
    'brick_lexer', 'brick_parser', 'brick_codegen', 'brick_shared',
    'brick_runtime',
] + platform_libs

if has_visualizer:
    brick_libs.remove('brick_runtime')
    brick_libs.append('brick_visualizer')
    brick_libs.append('brick_runtime')
    brick_libs.append('ncurses')

brick = env.Program('#build/brick', ['main.cpp'], LIBS=brick_libs)

Return('brick')
