{
    "publisher": "brick",
    "name": "brick-language",
    "displayName": "Brick Language",
    "description": "Brick language support: syntax highlighting, snippets, LSP, and debugger",
    "version": "0.4.0",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/nonunknown777/brick.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Debuggers"
    ],
    "activationEvents": [
        "onLanguage:brick",
        "onDebug"
    ],
    "main": "./out/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src --ext ts"
    },
    "extensionDependencies": [
        "ms-vscode.cpptools"
    ],
    "devDependencies": {
        "@types/node": "^20.19.43",
        "@types/vscode": "^1.80.0",
        "typescript": "^5.3.0"
    },
    "contributes": {
        "languages": [
            {
                "id": "brick",
                "aliases": [
                    "Brick",
                    "brick",
                    "brc"
                ],
                "extensions": [
                    ".brc"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "brick",
                "scopeName": "source.brc",
                "path": "./syntaxes/brick.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "brick",
                "path": "./snippets/brick.code-snippets"
            }
        ],
        "views": {
            "debug": [
                {
                    "id": "brick.memoryView",
                    "name": "Brick Memory",
                    "type": "webview"
                }
            ]
        },
        "commands": [
            {
                "command": "brick.initWorkspace",
                "title": "Brick: Init Workspace (create launch.json + tasks.json)"
            },
            {
                "command": "brick.debugProgram",
                "title": "Brick: Debug Program"
            }
        ],
        "semanticTokenScopes": [
            {
                "scopes": {
                    "keyword": [
                        "keyword.control.package.brc",
                        "keyword.control.struct.brc",
                        "keyword.control.function.brc",
                        "keyword.control.flow.brc",
                        "keyword.control.memory.brc"
                    ],
                    "type": [
                        "storage.type.brc"
                    ],
                    "class": [
                        "entity.name.type.struct.brc"
                    ],
                    "interface": [
                        "entity.name.type.interface.brc"
                    ],
                    "function": [
                        "entity.name.function.brc"
                    ],
                    "method": [
                        "entity.name.function.method.brc"
                    ],
                    "property": [
                        "variable.other.brc"
                    ],
                    "variable": [
                        "variable.other.brc"
                    ],
                    "string": [
                        "string.quoted.double.brc",
                        "string.quoted.single.brc"
                    ],
                    "number": [
                        "constant.numeric.integer.brc",
                        "constant.numeric.float.brc"
                    ],
                    "comment": [
                        "comment.line.double-slash.brc"
                    ],
                    "operator": [
                        "keyword.operator.arithmetic.brc",
                        "keyword.operator.comparison.brc",
                        "keyword.operator.logical.brc",
                        "keyword.operator.assignment.brc",
                        "keyword.operator.arrow.brc",
                        "keyword.operator.member.brc",
                        "keyword.operator.inc.brc"
                    ],
                    "parameter": [
                        "variable.parameter.brc"
                    ],
                    "struct": [
                        "entity.name.type.struct.brc"
                    ],
                    "constant": [
                        "constant.language.brc"
                    ]
                }
            }
        ],
        "colorize": true,
        "configurationDefaults": {
            "[brick]": {
                "editor.semanticHighlighting.enabled": true
            }
        },
        "debuggers": [
            {
                "type": "cppdbg",
                "label": "Brick",
                "configurationSnippets": [
                    {
                        "label": "Brick: Debug Compiler",
                        "description": "Debug the Brick compiler compiling the current .brc file",
                        "body": {
                            "name": "Debug Compiler (current file)",
                            "type": "cppdbg",
                            "request": "launch",
                            "program": "${workspaceFolder}/build/brick",
                            "args": [
                                "${file}",
                                "-o",
                                "${workspaceFolder}/build/${fileBasenameNoExtension}.c"
                            ],
                            "cwd": "${workspaceFolder}",
                            "MIMode": "gdb",
                            "setupCommands": [
                                {
                                    "description": "Enable pretty-printing for gdb",
                                    "text": "-enable-pretty-printing",
                                    "ignoreFailures": true
                                }
                            ],
                            "preLaunchTask": "Build (debug)"
                        }
                    },
                    {
                        "label": "Brick: Debug Program",
                        "description": "Compile and debug the current .brc file as a binary",
                        "body": {
                            "name": "Debug Compiled Program",
                            "type": "cppdbg",
                            "request": "launch",
                            "program": "${workspaceFolder}/build/${fileBasenameNoExtension}",
                            "args": [],
                            "cwd": "${workspaceFolder}",
                            "MIMode": "gdb",
                            "setupCommands": [
                                {
                                    "description": "Enable pretty-printing",
                                    "text": "-enable-pretty-printing",
                                    "ignoreFailures": true
                                },
                                {
                                    "description": "Load Brick printers",
                                    "text": "source ${workspaceFolder}/debugger/.gdbinit",
                                    "ignoreFailures": true
                                }
                            ],
                            "preLaunchTask": "Compile this .brc file"
                        }
                    },
                    {
                        "label": "Brick: Run Program",
                        "description": "Compile and run the current .brc file (no debugger UI)",
                        "body": {
                            "name": "Run Compiled Program",
                            "type": "cppdbg",
                            "request": "launch",
                            "program": "${workspaceFolder}/build/${fileBasenameNoExtension}",
                            "args": [],
                            "cwd": "${workspaceFolder}",
                            "MIMode": "gdb",
                            "preLaunchTask": "Compile this .brc file (release)"
                        }
                    }
                ],
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "program"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Path to the compiled binary"
                            },
                            "args": {
                                "type": "array",
                                "description": "Command line arguments to pass to the program"
                            },
                            "cwd": {
                                "type": "string",
                                "description": "Working directory for the debugged program"
                            },
                            "MIMode": {
                                "type": "string",
                                "enum": [
                                    "gdb",
                                    "lldb"
                                ],
                                "description": "Debugger backend (gdb recommended)"
                            }
                        }
                    }
                }
            }
        ]
    },
    "dependencies": {
        "vscode-languageclient": "^10.0.0"
    }
}
