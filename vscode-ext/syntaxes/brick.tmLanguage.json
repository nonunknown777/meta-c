{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Brick",
    "scopeName": "source.brc",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#builtin-types" },
        { "include": "#operators" },
        { "include": "#blocks-decl" },
        { "include": "#pointer-type" },
        { "include": "#at-annotation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "match": "//.*$",
                    "name": "comment.line.double-slash.brc"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "begin": "\"",
                    "end": "\"",
                    "name": "string.quoted.double.brc",
                    "patterns": [
                        {
                            "name": "constant.character.escape.brc",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "begin": "'",
                    "end": "'",
                    "name": "string.quoted.single.brc",
                    "patterns": [
                        {
                            "name": "constant.character.escape.brc",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "match": "\\b[0-9]+\\.[0-9]+\\b",
                    "name": "constant.numeric.float.brc"
                },
                {
                    "match": "\\b[0-9]+\\b",
                    "name": "constant.numeric.integer.brc"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.package.brc",
                    "match": "\\b(package|using|private|public|extern|include|link|and)\\b"
                },
                {
                    "name": "keyword.control.struct.brc",
                    "match": "\\b(struct|extends|interface)\\b"
                },
                {
                    "name": "keyword.control.function.brc",
                    "match": "\\b(fn|return)\\b"
                },
                {
                    "name": "keyword.control.flow.brc",
                    "match": "\\b(if|else|while|for)\\b"
                },
                {
                    "name": "keyword.control.memory.brc",
                    "match": "\\b(block|reset)\\b"
                },
                {
                    "name": "constant.language.brc",
                    "match": "\\b(true|false|null|error)\\b"
                }
            ]
        },
        "builtin-types": {
            "patterns": [
                {
                    "name": "storage.type.brc",
                    "match": "\\b(PoolAllocator|u(8|16|32|64)|i(8|16|32|64)|f(32|64)|usize|isize|byte|int|float|bool|char|String|void)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.brc",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.assignment.brc",
                    "match": "\\+=|-=|\\*=|/=|="
                },
                {
                    "name": "keyword.operator.comparison.brc",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.brc",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.arithmetic.brc",
                    "match": "\\+\\+|--|\\+|\\-|\\*|/"
                },
                {
                    "name": "keyword.operator.inc.brc",
                    "match": "\\+\\+|--"
                },
                {
                    "name": "keyword.operator.member.brc",
                    "match": "\\."
                },
                {
                    "name": "keyword.other.brc",
                    "match": ",|;|:"
                }
            ]
        },
        "pointer-type": {
            "patterns": [
                {
                    "name": "storage.modifier.pointer.brc",
                    "match": "(\\*)\\s*(?:(?:PoolAllocator|u(?:8|16|32|64)|i(?:8|16|32|64)|f(?:32|64)|usize|isize|byte|int|float|bool|char|String|void)\\b|[A-Z][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.operator.pointer.brc" }
                    }
                }
            ]
        },
        "at-annotation": {
            "patterns": [
                {
                    "name": "keyword.operator.at.brc",
                    "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "blocks-decl": {
            "patterns": [
                {
                    "name": "meta.block-declaration.brc",
                    "begin": "\\b(block)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=",
                    "beginCaptures": {
                        "1": { "name": "keyword.control.memory.brc" },
                        "2": { "name": "variable.name.block.brc" }
                    },
                    "end": "\\s*(KB|MB|GB)\\b",
                    "endCaptures": {
                        "1": { "name": "keyword.other.unit.brc" }
                    },
                    "patterns": [
                        { "include": "#numbers" }
                    ]
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "entity.name.type.struct.brc",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                },
                {
                    "name": "variable.other.brc",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
